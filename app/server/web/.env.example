# Sage 前端开发环境配置
#
# 使用方法：
# 复制此文件为 .env.development：cp .env.example .env.development
#
# 注意：此目录下 .env.development 中的 VITE_SAGE_API_BASE_URL 决定 dev 代理目标（与 server、Docker 端口一致即可）

NODE_ENV=development

# 后端 API 地址（仅 Vite dev 反代目标；不读仓库根 .env）
# VITE_SAGE_API_BASE_URL=http://127.0.0.1:30050

# Web 基础路径
# 如果部署在子路径下，修改为 /your-path/
VITE_SAGE_WEB_BASE_PATH=/

# API 前缀
VITE_BACKEND_API_PREFIX=/api

# 链路追踪（可选）
# VITE_SAGE_TRACE_WEB_URL=http://127.0.0.1:30051/jaeger/
