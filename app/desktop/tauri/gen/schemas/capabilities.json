{
    "default": {
        "identifier": "default",
        "description": "Main window capability",
        "local": true,
        "windows": [
            "main"
        ],
        "permissions": [
            "core:default",
            "core:app:default",
            "core:event:default",
            "core:window:default",
            "core:path:default",
            "core:menu:default",
            "core:tray:default",
            "dialog:default",
            "fs:default",
            "fs:allow-write-text-file",
            "shell:default",
            {
                "identifier": "fs:scope",
                "allow": [
                    {
                        "path": "$HOME/**"
                    },
                    {
                        "path": "$DOWNLOAD/**"
                    },
                    {
                        "path": "$DOCUMENT/**"
                    },
                    {
                        "path": "$DESKTOP/**"
                    },
                    {
                        "path": "$RESOURCE/**"
                    }
                ]
            }
        ]
    }
}