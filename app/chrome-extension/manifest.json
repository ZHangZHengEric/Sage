{
  "manifest_version": 3,
  "name": "Sage",
  "description": "Sage Desktop browser companion extension.",
  "version": "0.1.0",
  "icons": {
    "16": "sage_logo.png",
    "32": "sage_logo.png",
    "48": "sage_logo.png",
    "128": "sage_logo.png"
  },
  "action": {
    "default_title": "Sage",
    "default_icon": {
      "16": "sage_logo.png",
      "32": "sage_logo.png",
      "48": "sage_logo.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "sage_logo.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "alarms",
    "activeTab",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ]
}
