# Sage 精简开发配置
#
# 适用场景：
# - 本地快速开发
# - 无需外部依赖（MySQL/ES/RustFS）
# - 使用 SQLite 文件数据库
#
# 使用方法：
# 1. 复制此文件为 .env：cp .env.example.minimal .env
# 2. 根据需要修改配置（特别是 LLM API Key）
# 3. 运行：./scripts/dev-up.sh

# Sage 环境标识
SAGE_ROOT=./data
SAGE_ENV=development

# Web 基础路径
SAGE_WEB_BASE_PATH=/

# 数据库配置：使用 SQLite（无需额外安装）
SAGE_DB_TYPE=sqlite
SAGE_SQLITE_PATH=./data/sage.db

# 认证模式：native（最简单，内置用户名密码登录）
SAGE_AUTH_MODE=native

# 可选：Bootstrap 管理员账户（只在账户不存在时创建）
SAGE_BOOTSTRAP_ADMIN_USERNAME=admin
SAGE_BOOTSTRAP_ADMIN_PASSWORD=admin.1234

# JWT / Session secrets（开发环境可以使用默认值，生产环境必须修改）
SAGE_JWT_KEY=dev_jwt_secret_key_change_in_production
SAGE_REFRESH_TOKEN_SECRET=dev_refresh_secret_change_in_production
SAGE_SESSION_SECRET=dev_session_secret_change_in_production
SAGE_SESSION_COOKIE_NAME=sage_session
SAGE_SESSION_COOKIE_SECURE=false
SAGE_SESSION_COOKIE_SAME_SITE=lax

# CORS 配置
SAGE_CORS_ALLOWED_ORIGINS=*
SAGE_CORS_ALLOW_CREDENTIALS=false
SAGE_CORS_ALLOW_METHODS=*
SAGE_CORS_ALLOW_HEADERS=*
SAGE_CORS_EXPOSE_HEADERS=
SAGE_CORS_MAX_AGE=600

# 默认 LLM 配置（必须配置）
SAGE_DEFAULT_LLM_API_KEY=
SAGE_DEFAULT_LLM_API_BASE_URL=https://api.deepseek.com/v1
SAGE_DEFAULT_LLM_MODEL_NAME=deepseek-chat
SAGE_DEFAULT_LLM_MAX_TOKENS=4096
SAGE_DEFAULT_LLM_TEMPERATURE=0.2

# 沙箱配置：本地模式
SAGE_SANDBOX_MODE=local
SAGE_LOCAL_CPU_TIME_LIMIT=300
SAGE_LOCAL_MEMORY_LIMIT_MB=4096

# macOS 隔离模式：seatbelt（推荐）或 subprocess
SAGE_LOCAL_MACOS_ISOLATION=seatbelt

# Linux 隔离模式：subprocess（容器）或 bwrap（宿主机）
SAGE_LOCAL_LINUX_ISOLATION=subprocess

# Embedding 配置（可选，用于向量搜索）
# SAGE_EMBEDDING_API_KEY=
# SAGE_EMBEDDING_BASE_URL=https://api.deepseek.com/v1/
# SAGE_EMBEDDING_MODEL=text-embedding-v4
# SAGE_EMBEDDING_DIMS=1024

# 可选服务（不配置也不影响启动）
# 如需使用 Elasticsearch：
# SAGE_ELASTICSEARCH_URL=http://localhost:9200
# SAGE_ELASTICSEARCH_PORT=9200
# SAGE_ELASTICSEARCH_USERNAME=
# SAGE_ELASTICSEARCH_PASSWORD=

# 如需使用对象存储（RustFS/MinIO）：
# SAGE_S3_ENDPOINT=localhost:9000
# SAGE_S3_ACCESS_KEY=
# SAGE_S3_SECRET_KEY=
# SAGE_S3_SECURE=false
# SAGE_S3_BUCKET_NAME=sage
# SAGE_S3_PUBLIC_BASE_URL=http://localhost:9000/sage
